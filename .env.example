# ─── Database ────────────────────────────────────────────────────────────────
# SQL Server 2022 - Windows Auth
ConnectionStrings__DefaultConnection=Server=localhost\SQLEXPRESS;Database=PayrollDb;Trusted_Connection=True;TrustServerCertificate=True;

# SQL Server 2022 - SQL Auth
# ConnectionStrings__DefaultConnection=Server=localhost\SQLEXPRESS;Database=PayrollDb;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;

# ─── JWT ─────────────────────────────────────────────────────────────────────
Jwt__Issuer=PayrollApi
Jwt__Audience=PayrollApiClients
Jwt__SecretKey=REPLACE_WITH_MINIMUM_32_CHAR_SECRET_KEY
Jwt__ExpiryMinutes=60

# ─── CORS ─────────────────────────────────────────────────────────────────────
AllowedOrigins__0=http://localhost:4200
AllowedOrigins__1=https://your-production-domain.com

# ─── Logging ─────────────────────────────────────────────────────────────────
Serilog__MinimumLevel__Default=Information
